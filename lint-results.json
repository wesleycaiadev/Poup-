     <directionalLight position={[-5, 5, 5]} intensity={1} />\r\n        \r\n        <Suspense fallback={null}>\r\n          {children}\r\n          <Environment preset=\"city\" />\r\n        </Suspense>\r\n\r\n        <OrbitControls enableZoom={false} enablePan={false} maxPolarAngle={Math.PI / 2} minPolarAngle={Math.PI / 3} />\r\n      </Canvas>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default SceneView;\r\n[1/1]\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Wesley\\Documents\\gastos\\src\\components\\ui\\bottom-sheet.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Wesley\\Documents\\gastos\\src\\components\\ui\\glass-card.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Wesley\\Documents\\gastos\\src\\constants\\categories.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Wesley\\Documents\\gastos\\src\\hooks\\use-expense-store.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CategoryId' is defined but never used.","line":3,"column":19,"nodeType":"Identifier","messageId":"unusedVar","endLine":3,"endColumn":29,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"CategoryId"},"fix":{"range":[117,129],"text":""},"desc":"Remove unused variable \"CategoryId\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { create } from 'zustand';\r\nimport { persist, createJSONStorage } from 'zustand/middleware';\r\nimport { Expense, CategoryId } from '@/types/expense';\r\n\r\nexport interface ExpenseState {\r\n  expenses: Expense[];\r\n  userName: string;\r\n  userAvatar: string;\r\n  budget: number;\r\n  addExpense: (expense: Omit<Expense, 'id' | 'date'>) => void;\r\n  removeExpense: (id: string) => void;\r\n  setBudget: (amount: number) => void;\r\n  setProfile: (name: string, avatar: string) => void;\r\n  getTotalExpenses: () => number;\r\n}\r\n\r\nexport const useExpenseStore = create<ExpenseState>()(\r\n  persist(\r\n    (set, get) => ({\r\n      expenses: [],\r\n      userName: '',\r\n      userAvatar: '',\r\n      budget: 5000,\r\n      addExpense: (expense) => {\r\n        const newExpense: Expense = {\r\n          ...expense,\r\n          id: crypto.randomUUID(),\r\n          date: new Date().toISOString(),\r\n        };\r\n        set((state) => ({\r\n          expenses: [newExpense, ...state.expenses],\r\n        }));\r\n      },\r\n      removeExpense: (id) => {\r\n        set((state) => ({\r\n          expenses: state.expenses.filter((e) => e.id !== id),\r\n        }));\r\n      },\r\n      setBudget: (amount) => set({ budget: amount }),\r\n      setProfile: (name, avatar) => set({ userName: name, userAvatar: avatar }),\r\n      getTotalExpenses: () => {\r\n        return get().expenses.reduce((total, expense) => total + expense.amount, 0);\r\n      },\r\n    }),\r\n    {\r\n      name: 'expense-storage', // Nome da chave no localStorage\r\n      storage: createJSONStorage(() => localStorage),\r\n    }\r\n  )\r\n);\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Wesley\\Documents\\gastos\\src\\lib\\formatters.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Wesley\\Documents\\gastos\\src\\lib\\supabase-browser.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Wesley\\Documents\\gastos\\src\\lib\\supabase-server.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Wesley\\Documents\\gastos\\src\\lib\\utils.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Wesley\\Documents\\gastos\\src\\middleware.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'serializeCookieHeader' is defined but never used.","line":1,"column":30,"nodeType":"Identifier","messageId":"unusedVar","endLine":1,"endColumn":51,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"serializeCookieHeader"},"fix":{"range":[27,50],"text":""},"desc":"Remove unused variable \"serializeCookieHeader\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createServerClient, serializeCookieHeader } from '@supabase/ssr';\nimport { NextResponse, type NextRequest } from 'next/server';\n\nexport async function middleware(request: NextRequest) {\n  let supabaseResponse = NextResponse.next({\n    request,\n  });\n\n  const supabase = createServerClient(\n    process.env.NEXT_PUBLIC_SUPABASE_URL!,\n    process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,\n    {\n      cookies: {\n        getAll() {\n          return request.cookies.getAll();\n        },\n        setAll(cookiesToSet) {\n          cookiesToSet.forEach(({ name, value }) =>\n            request.cookies.set(name, value)\n          );\n          supabaseResponse = NextResponse.next({ request });\n          cookiesToSet.forEach(({ name, value, options }) =>\n            supabaseResponse.cookies.set(name, value, options)\n          );\n        },\n      },\n    }\n  );\n\n  // IMPORTANTE: Usar getUser() para valida├º├úo segura no server\n  const {\n    data: { user },\n  } = await supabase.auth.getUser();\n\n  const { pathname } = request.nextUrl;\n\n  const publicRoutes = ['/login', '/auth/callback'];\n  const isPublicRoute = publicRoutes.some((route) =>\n    pathname.startsWith(route)\n  );\n\n  if (!user && !isPublicRoute) {\n    const url = request.nextUrl.clone();\n    url.pathname = '/login';\n    return NextResponse.redirect(url);\n  }\n\n  if (user && pathname === '/login') {\n    const url = request.nextUrl.clone();\n    url.pathname = '/';\n    return NextResponse.redirect(url);\n  }\n\n  return supabaseResponse;\n}\n\nexport const config = {\n  matcher: [\n    '/((?!_next/static|_next/image|favicon.ico|manifest.json|icons|sw.js|workbox-.*|.*\\\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)',\n  ],\n};\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Wesley\\Documents\\gastos\\src\\types\\expense.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
